# OpenFOV configuration — copy to ".env" and edit.
#
# Destination for the UDP/JSON pose output. OpenFOV sends one datagram per
# tracked frame: {"rotation": [heading, pitch, roll]} (degrees).
#
# Format: udp://HOST:PORT  (the "udp://" scheme is optional; HOST:PORT works too)
# Default when unset: udp://127.0.0.1:4242
OPENFOV_UDP_TARGET=udp://127.0.0.1:4242
